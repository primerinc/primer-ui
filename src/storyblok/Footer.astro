---
/**
 * Footer
 * Storyblok block name: footer
 *
 * Fields: logo, tagline, columns (→ footer_column), social_links (→ social_link),
 *         newsletter_enabled, newsletter_heading, copyright, legal_links (→ nav_link)
 */
import { storyblokEditable } from '@storyblok/astro';

const { blok } = Astro.props;

const logoUrl          = blok.logo?.filename;
const logoAlt          = blok.logo?.alt || 'Logo';
const columns          = blok.columns || [];
const socialLinks      = blok.social_links || [];
const legalLinks       = blok.legal_links || [];
const newsletterOn     = blok.newsletter_enabled ?? false;

const socialIcons: Record<string, string> = {
  linkedin:  '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.354V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.284zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
  x:         '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
  facebook:  '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>',
  instagram: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>',
  youtube:   '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>',
};
---

<footer class="site-footer" {...storyblokEditable(blok)}>
  <div class="site-footer__inner">

    <div class="site-footer__top">

      <div class="site-footer__brand">
        <a href="/" class="site-footer__logo">
          {logoUrl
            ? <img src={`${logoUrl}/m/200x0`} alt={logoAlt} width="160" height="40" />
            : <span class="site-footer__logo-text">{logoAlt}</span>
          }
        </a>
        {blok.tagline && <p class="site-footer__tagline">{blok.tagline}</p>}

        {socialLinks.length > 0 && (
          <div class="site-footer__social">
            {socialLinks.map((s: any) => {
              const href = s.url?.url || s.url?.cached_url || '#';
              const icon = socialIcons[s.platform?.toLowerCase()] || '';
              return (
                <a
                  href={href}
                  class="site-footer__social-link"
                  aria-label={s.platform}
                  target="_blank"
                  rel="noopener noreferrer"
                  {...storyblokEditable(s)}
                  set:html={icon}
                />
              );
            })}
          </div>
        )}
      </div>

      <div class="site-footer__columns">
        {columns.map((col: any) => {
          const links = col.links || [];
          return (
            <div class="footer-col" {...storyblokEditable(col)}>
              {col.heading && <p class="footer-col__heading">{col.heading}</p>}
              <ul class="footer-col__list" role="list">
                {links.map((link: any) => {
                  const href = link.link?.url || link.link?.cached_url || '#';
                  return (
                    <li {...storyblokEditable(link)}>
                      <a href={href} class="footer-col__link">{link.label}</a>
                    </li>
                  );
                })}
              </ul>
            </div>
          );
        })}

        {newsletterOn && (
          <div class="footer-col footer-col--newsletter">
            <p class="footer-col__heading">{blok.newsletter_heading || 'Stay in the loop'}</p>
            <form class="newsletter-form" onsubmit="return false;">
              <input
                type="email"
                class="newsletter-form__input"
                placeholder="Your email address"
                aria-label="Email address"
                required
              />
              <button type="submit" class="newsletter-form__btn">Subscribe</button>
            </form>
          </div>
        )}
      </div>

    </div>

    <div class="site-footer__bottom">
      {blok.copyright && <p class="site-footer__copyright">{blok.copyright}</p>}
      {legalLinks.length > 0 && (
        <ul class="site-footer__legal" role="list">
          {legalLinks.map((link: any) => {
            const href = link.link?.url || link.link?.cached_url || '#';
            return (
              <li {...storyblokEditable(link)}>
                <a href={href} class="site-footer__legal-link">{link.label}</a>
              </li>
            );
          })}
        </ul>
      )}
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: var(--p-color-bg-inverse);
    color: var(--p-color-text-inverse);
    padding-top: var(--p-space-16);
  }

  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--p-space-6);
  }

  /* ── Top section ────────────────────────────────────────────── */
  .site-footer__top {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--p-space-16);
    padding-bottom: var(--p-space-12);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  /* ── Brand column ───────────────────────────────────────────── */
  .site-footer__logo {
    display: inline-flex;
    margin-bottom: var(--p-space-4);
    text-decoration: none;
  }

  .site-footer__logo img { height: 36px; width: auto; display: block; }

  .site-footer__logo-text {
    font-family: var(--p-font-display);
    font-size: var(--p-font-size-lg);
    font-weight: var(--p-font-weight-semibold);
    color: var(--p-color-text-inverse);
  }

  .site-footer__tagline {
    font-family: var(--p-font-body);
    font-size: var(--p-font-size-sm);
    font-weight: var(--p-font-weight-light);
    color: rgba(255,255,255,0.6);
    line-height: var(--p-font-leading-normal);
    margin-bottom: var(--p-space-6);
  }

  /* ── Social ─────────────────────────────────────────────────── */
  .site-footer__social {
    display: flex;
    gap: var(--p-space-3);
    margin-top: var(--p-space-2);
  }

  .site-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--p-radius-sm);
    color: rgba(255,255,255,0.6);
    transition: color 0.15s ease, background 0.15s ease;
    text-decoration: none;
  }

  .site-footer__social-link:hover {
    color: var(--p-color-text-inverse);
    background: rgba(255,255,255,0.1);
  }

  /* ── Link columns ───────────────────────────────────────────── */
  .site-footer__columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--p-space-8);
  }

  .footer-col__heading {
    font-family: var(--p-font-body);
    font-size: var(--p-font-size-xs);
    font-weight: var(--p-font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--p-font-tracking-wide);
    color: rgba(255,255,255,0.45);
    margin-bottom: var(--p-space-4);
  }

  .footer-col__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--p-space-3);
  }

  .footer-col__link {
    font-family: var(--p-font-body);
    font-size: var(--p-font-size-sm);
    font-weight: var(--p-font-weight-regular);
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-col__link:hover { color: var(--p-color-text-inverse); }

  /* ── Newsletter ─────────────────────────────────────────────── */
  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: var(--p-space-2);
  }

  .newsletter-form__input {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--p-radius-sm);
    padding: var(--p-space-2) var(--p-space-3);
    font-family: var(--p-font-body);
    font-size: var(--p-font-size-sm);
    color: var(--p-color-text-inverse);
    width: 100%;
  }

  .newsletter-form__input::placeholder { color: rgba(255,255,255,0.4); }
  .newsletter-form__input:focus { outline: none; border-color: var(--p-color-accent-default); }

  .newsletter-form__btn {
    background: var(--p-color-accent-default);
    color: var(--p-color-text-inverse);
    border: none;
    border-radius: var(--p-radius-button);
    padding: var(--p-space-2) var(--p-space-4);
    font-family: var(--p-font-body);
    font-size: var(--p-font-size-sm);
    font-weight: var(--p-font-weight-medium);
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .newsletter-form__btn:hover { opacity: 0.85; }

  /* ── Bottom bar ─────────────────────────────────────────────── */
  .site-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--p-space-6);
    padding: var(--p-space-6) 0;
    flex-wrap: wrap;
  }

  .site-footer__copyright {
    font-family: var(--p-font-body);
    font-size: var(--p-font-size-xs);
    color: rgba(255,255,255,0.4);
  }

  .site-footer__legal {
    display: flex;
    gap: var(--p-space-6);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .site-footer__legal-link {
    font-family: var(--p-font-body);
    font-size: var(--p-font-size-xs);
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .site-footer__legal-link:hover { color: rgba(255,255,255,0.7); }

  /* ── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .site-footer__top {
      grid-template-columns: 1fr;
      gap: var(--p-space-10);
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
