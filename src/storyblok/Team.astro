---
/**
 * Team
 * Storyblok block name: team
 *
 * Fields: eyebrow, headline, subheadline, members (blocks → team_member), columns, layout
 * team_member fields: photo, name, title, bio, linkedin_url
 */
import { storyblokEditable } from '@storyblok/astro';
import type { SbBlokData } from '@storyblok/astro';

interface TeamMember extends SbBlokData {
  photo?: { filename: string; alt?: string };
  name?: string;
  title?: string;
  bio?: string;
  linkedin_url?: string;
}

const { blok } = Astro.props;

const columns = blok.columns || 3;
const layout  = blok.layout || 'card';
const bg      = blok.background || 'primary';
---

<section {...storyblokEditable(blok)} class:list={['team', `team--bg-${bg}`]}>
  <div class="team__inner">
    {(blok.eyebrow || blok.headline || blok.subheadline) && (
      <div class="team__header">
        {blok.eyebrow && <p class="team__eyebrow">{blok.eyebrow}</p>}
        {blok.headline && <h2 class="team__headline">{blok.headline}</h2>}
        {blok.subheadline && <p class="team__sub">{blok.subheadline}</p>}
      </div>
    )}

    <ul class:list={['team__list', `team__list--${columns}`, `team__list--${layout}`]} role="list">
      {(blok.members as TeamMember[])?.map((member) => {
        const photoUrl = member.photo?.filename
          ? `${member.photo.filename}/m/400x400/filters:quality(85)`
          : null;

        return (
          <li class="member" {...storyblokEditable(member)}>
            <div class="member__photo-wrap">
              {photoUrl
                ? <img src={photoUrl} alt={member.photo?.alt ?? member.name ?? ''} class="member__photo" loading="lazy" />
                : <div class="member__photo-placeholder" aria-hidden="true" />
              }
            </div>
            <div class="member__body">
              {member.name && <h3 class="member__name">{member.name}</h3>}
              {member.title && <p class="member__title">{member.title}</p>}
              {member.bio && <p class="member__bio">{member.bio}</p>}
              {member.linkedin_url && (
                <a href={String(member.linkedin_url)} class="member__linkedin" target="_blank" rel="noopener noreferrer" aria-label={`${member.name} on LinkedIn`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
            </div>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<style>
  .team--bg-secondary     { background: var(--p-color-bg-secondary); }
  .team--bg-accent-subtle { background: var(--p-color-bg-accent); }

  .team {
    padding: var(--p-space-24) var(--p-space-8);
    background: var(--p-color-bg-primary);
  }

  .team__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .team__header {
    max-width: 640px;
    margin: 0 auto var(--p-space-16);
    text-align: center;
  }

  .team__eyebrow {
    font-size: var(--p-font-size-xs);
    font-weight: var(--p-font-weight-medium);
    letter-spacing: var(--p-font-tracking-wider);
    text-transform: uppercase;
    color: var(--p-color-text-tertiary);
    margin-bottom: var(--p-space-3);
  }

  .team__headline {
    font-family: var(--p-font-display);
    font-size: var(--p-font-size-3xl);
    font-weight: var(--p-font-weight-semibold);
    line-height: var(--p-font-leading-tight);
    color: var(--p-color-text-primary);
    margin-bottom: var(--p-space-4);
  }

  .team__sub {
    font-size: var(--p-font-size-lg);
    font-weight: var(--p-font-weight-light);
    color: var(--p-color-text-secondary);
    line-height: var(--p-font-leading-normal);
  }

  /* Grid */
  .team__list {
    display: grid;
    gap: var(--p-space-8);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .team__list--2 { grid-template-columns: repeat(2, 1fr); }
  .team__list--3 { grid-template-columns: repeat(3, 1fr); }
  .team__list--4 { grid-template-columns: repeat(4, 1fr); }

  @media (max-width: 1024px) {
    .team__list--4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 900px) {
    .team__list--3 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 580px) {
    .team__list--2,
    .team__list--3,
    .team__list--4 { grid-template-columns: 1fr; }
  }

  /* Member card (default) */
  .member {
    display: flex;
    flex-direction: column;
    background: var(--p-color-bg-primary);
    border: 1px solid var(--p-color-border-default);
    border-radius: var(--p-radius-card);
    overflow: hidden;
  }

  .team__list--minimal .member {
    border: none;
    border-radius: 0;
    text-align: center;
    align-items: center;
    background: transparent;
  }

  .member__photo-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--p-color-bg-secondary);
  }

  .team__list--minimal .member__photo-wrap {
    width: 160px;
    border-radius: 50%;
  }

  .member__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .member__photo-placeholder {
    width: 100%;
    height: 100%;
    background: var(--p-color-bg-secondary);
  }

  .member__body {
    padding: var(--p-space-6);
    display: flex;
    flex-direction: column;
    gap: var(--p-space-2);
    flex: 1;
  }

  .team__list--minimal .member__body {
    padding: var(--p-space-4) 0 0;
    align-items: center;
  }

  .member__name {
    font-family: var(--p-font-body);
    font-size: var(--p-font-size-lg);
    font-weight: var(--p-font-weight-semibold);
    color: var(--p-color-text-primary);
    line-height: var(--p-font-leading-snug);
  }

  .member__title {
    font-size: var(--p-font-size-sm);
    font-weight: var(--p-font-weight-medium);
    color: var(--p-color-text-accent);
  }

  .member__bio {
    font-size: var(--p-font-size-sm);
    font-weight: var(--p-font-weight-light);
    color: var(--p-color-text-secondary);
    line-height: var(--p-font-leading-normal);
    margin-top: var(--p-space-2);
    flex: 1;
  }

  .member__linkedin {
    display: inline-flex;
    align-items: center;
    margin-top: var(--p-space-3);
    color: var(--p-color-text-tertiary);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .member__linkedin:hover {
    color: var(--p-color-text-accent);
  }
</style>
