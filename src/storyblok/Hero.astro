---
/**
 * Hero
 * Storyblok block name: hero
 *
 * Fields: headline, subheadline, buttons (Blocks → button), background_image, layout
 */
import { storyblokEditable } from '@storyblok/astro';

const { blok } = Astro.props;

const layout = blok.layout || 'centered';
const bg     = blok.background || 'secondary';

const imageUrl = blok.background_image?.filename
  ? `${blok.background_image.filename}/m/1600x0/filters:quality(80)`
  : null;

const buttons = blok.buttons || [];
---

<section
  {...storyblokEditable(blok)}
  class:list={['hero', `hero--${layout}`, `hero--bg-${bg}`]}
  style={imageUrl ? `--hero-bg: url('${imageUrl}')` : ''}
>
  <div class="hero__inner">
    <h1 class="hero__headline">{blok.headline}</h1>
    {blok.subheadline && <p class="hero__sub">{blok.subheadline}</p>}
    {buttons.length > 0 && (
      <div class="hero__actions">
        {buttons.map((btn: any) => (
          <a
            href={btn.link?.url || btn.link?.cached_url || '#'}
            class:list={['btn', `btn--${btn.variant || 'primary'}`]}
            {...storyblokEditable(btn)}
          >
            {btn.text}
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .hero--bg-primary       { background-color: var(--p-color-bg-primary); }
  .hero--bg-accent-subtle { background-color: var(--p-color-bg-accent); }

  .hero {
    background-color: var(--p-color-bg-secondary);
    padding: var(--p-space-24) var(--p-space-8);
    position: relative;
  }

  .hero__inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .hero--centered .hero__inner {
    text-align: center;
  }

  .hero__headline {
    font-family: var(--p-font-display);
    font-size: var(--p-font-size-4xl);
    font-weight: var(--p-font-weight-semibold);
    line-height: var(--p-font-leading-tight);
    color: var(--p-color-text-primary);
    margin-bottom: var(--p-space-6);
  }

  .hero__sub {
    font-family: var(--p-font-body);
    font-size: var(--p-font-size-lg);
    font-weight: var(--p-font-weight-light);
    color: var(--p-color-text-secondary);
    max-width: 600px;
    margin-bottom: var(--p-space-10);
  }

  .hero--centered .hero__sub {
    margin-inline: auto;
  }

  .hero__actions {
    display: flex;
    gap: var(--p-space-4);
    flex-wrap: wrap;
  }

  .hero--centered .hero__actions {
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--p-space-3) var(--p-space-8);
    border-radius: var(--p-radius-button);
    font-family: var(--p-font-body);
    font-size: var(--p-font-size-sm);
    font-weight: var(--p-font-weight-medium);
    letter-spacing: var(--p-font-tracking-wide);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .btn:hover { opacity: 0.85; }

  .btn--primary {
    background: var(--p-color-accent-default);
    color: var(--p-color-text-inverse);
  }

  .btn--secondary {
    background: transparent;
    color: var(--p-color-text-primary);
    border: 1px solid var(--p-color-border-default);
  }
</style>
