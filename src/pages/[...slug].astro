---
import { useStoryblokApi } from '@storyblok/astro';
import type { SbBlokData } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const api = useStoryblokApi();
  const { data } = await api.get('cdn/stories', {
    version: 'draft',
    excluding_slugs: 'home',
  });

  return data.stories.map((story: { full_slug: string; name: string; content: Record<string, unknown> }) => ({
    params: { slug: story.full_slug },
    props: { story },
  }));
}

interface Story {
  name: string;
  content: SbBlokData;
}

const { story } = Astro.props as { story: Story };
---

<BaseLayout title={story.name}>
  <StoryblokComponent blok={story.content} />
</BaseLayout>
