{
  "name": "@primer-inc/ui",
  "version": "0.1.0",
  "description": "Primer shared component library for Astro + Storyblok client builds",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build:tokens": "style-dictionary build --config tokens/sd.config.js",
    "build:tokens:wireframe": "PRIMER_THEME=wireframe style-dictionary build --config tokens/sd.config.js",
    "watch:tokens": "style-dictionary build --watch --config tokens/sd.config.js",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview"
  },
  "keywords": [
    "astro",
    "storyblok",
    "design-tokens",
    "component-library"
  ],
  "author": "Primer <hello@primerinc.com>",
  "dependencies": {
    "@storyblok/astro": "^9.0.12",
    "astro": "^6.4.6",
    "style-dictionary": "^5.4.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3",
    "vite-plugin-mkcert": "^1.17.12"
  }
}
